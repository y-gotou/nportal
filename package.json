{
  "name": "nportal",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt typecheck",
    "test": "node --experimental-strip-types --test tests/*.test.ts tests/*.test.mjs",
    "check": "npm run typecheck && npm run build",
    "preview": "npm run build && wrangler pages dev dist",
    "db:seed:local": "node scripts/d1-execute.mjs local db/schema.sql && node scripts/d1-execute.mjs local db/seed.sql",
    "db:schema:local": "node scripts/d1-execute.mjs local db/schema.sql",
    "db:schema:prod": "node scripts/d1-execute.mjs prod db/schema.sql",
    "db:schema:preview": "node scripts/d1-execute.mjs preview db/schema.sql",
    "db:migrate:local": "node scripts/d1-execute.mjs local db/migrate.sql",
    "db:migrate:prod": "node scripts/d1-execute.mjs prod db/migrate.sql",
    "db:migrate:preview": "node scripts/d1-execute.mjs preview db/migrate.sql",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.1",
    "wrangler": "^4.78.0"
  }
}
